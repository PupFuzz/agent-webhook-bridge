#!/usr/bin/env bash
# promote-released-cards — move a release's tracking cards to a "released" stage.
#
# Generic across repos (sibling to release-pr-body). Board / stage / API base come
# from `.release-pr.json` (`.promote` block); the API token comes from
# $KANBAN_WRITEBACK_TOKEN. A card is "shipped in this release" if EITHER its
# `payload.dl_number` matches a shipped DL token OR its `payload.pr_number` matches
# a shipped PR number — so cards tracked only by PR (no DL) are promoted too.
# Idempotent (skips a card already at target), best-effort per card.
#
# Shipped refs come from `--dls "DL-1,DL-2"` (DL-only), else from `git log <base>..<head>`:
#   - DL tokens via `ref_token_regex` (default DL-[0-9]+), matched on the numeric part;
#   - PR numbers from each commit's trailing `(#NNN)` (the squash-merge marker GitHub appends).
#
# Robustness (these states are silent-but-wrong, so they're made loud):
#   - 0 visible cards on page 1 => FAIL (token's user not a board member / wrong instance).
#   - Reads the WHOLE board by paging (`page=N`), so a board >200 cards is not truncated.
#   - A shipped ref that matched NO card is reported at the end (a card may be unstamped).
#   - Nothing NEWLY promoted despite a non-empty shipped-ref set => the exit is decided
#     by the ROOT CAUSE: a MERGE-commit release tip (or explicit --dls) means ref-derivation
#     was COMPLETE, so the DLs are genuinely cardless => WARN (exit 0); a non-merge tip means
#     a squash/rebase merge may have dropped the per-PR refs (the v0.32.0 silent-green class)
#     => FAIL (exit 2). This converges two divergent prior behaviors: the bridge copy
#     blanket-failed any 0-promoted run (DL-165), the toolkit/kanban copies exited 0
#     silently — neither distinguished the cause.
#   - Assumes it fires on a RELEASE merge to a protected main (push==release-merge). A plain
#     non-merge commit pushed directly to main whose range carries cardless DLs would fail
#     loud by the same rule — intended, given the assumption.
#
# Usage: promote-released-cards [--dls LIST] [--base REF] [--head REF] [--dry-run] [--config PATH]
set -euo pipefail

die() { echo "promote-released-cards: $*" >&2; exit 2; }
for c in jq curl git; do command -v "$c" >/dev/null || die "$c is required"; done

# host_ok <api_base>: true iff api_base is https:// and its host is $EXPECT_HOST or a
# subdomain of it. Assumes $EXPECT_HOST is non-empty (the caller enforces that before
# calling — see the required-var check below). Host is parsed per RFC 3986 (userinfo
# before the last '@' stripped, then :port), so `https://good@evil/` (→ evil) and
# `https://good.evil/` are both rejected. Mirrors kb_require_https_host in
# _kb-board-lib.sh — this script is vendored standalone into consumer repos and MUST NOT
# source that lib, so the guard is duplicated; keep the two in sync, INCLUDING the
# required-var check. (#3570)
host_ok() {
  case "$1" in https://*) ;; *) return 1 ;; esac
  local h="${1#https://}"; h="${h%%/*}"; h="${h##*@}"; h="${h%%:*}"
  [ -n "$h" ] || return 1
  [ "$h" = "$EXPECT_HOST" ] && return 0
  case "$h" in *".$EXPECT_HOST") return 0 ;; *) return 1 ;; esac
}

# True iff <ref> is a MERGE commit (>=2 parents). `git rev-list --parents -n1`
# prints "<sha> <parent1> <parent2>..." → >=3 tokens ⇒ merge. A merge-commit release
# tip means the range carries every feature/prep commit subject, so the ref-derivation
# was COMPLETE; a non-merge tip (squash/rebase) may have collapsed it. git failure
# (unknown ref / shallow graft) ⇒ non-merge (fail-loud-safe). CI checks out
# fetch-depth:0, so parents are real.
merge_commit_tip() {
  local line
  line="$(git rev-list --parents -n1 "$1" 2>/dev/null)" || return 1
  [ "$(printf '%s' "$line" | wc -w)" -ge 3 ]
}

CONFIG=".release-pr.json"; DLS_IN=""; BASE=""; HEAD_REF=""; DRY=0
while [ $# -gt 0 ]; do
  case "$1" in
    --dls)     DLS_IN="$2"; shift 2;;
    --base)    BASE="$2"; shift 2;;
    --head)    HEAD_REF="$2"; shift 2;;
    --dry-run) DRY=1; shift;;
    --config)  CONFIG="$2"; shift 2;;
    -h|--help) sed -n '2,20p' "$0"; exit 0;;
    *) die "unknown arg '$1'";;
  esac
done

# SECURITY: .release-pr.json is security-sensitive — .promote.api_base is where the
# writeback token (KANBAN_WRITEBACK_TOKEN) is sent. A PR editing api_base to point at an
# attacker host would exfiltrate the token on the next promote CI run. board_id/stage are
# validated numeric below; api_base is host-validated (https + $EXPECT_HOST) before any
# token is sent (#3570). Treat any api_base change in a PR as a credential-scope change.
[ -f "$CONFIG" ] || die "no $CONFIG in this repo"
cfg() { jq -r "$1 // empty" "$CONFIG"; }
BOARD="$(cfg '.promote.board_id')"
STAGE="$(cfg '.promote.released_stage_id')"
API="$(cfg '.promote.api_base')"
REF_RE="$(cfg '.ref_token_regex')"; REF_RE="${REF_RE:-DL-[0-9]+}"
[ -n "$BOARD" ] && [ -n "$STAGE" ] && [ -n "$API" ] \
  || die ".promote.{board_id,released_stage_id,api_base} are required in $CONFIG"
case "$BOARD" in ''|*[!0-9]*) die ".promote.board_id must be numeric (got '$BOARD')";; esac
case "$STAGE" in ''|*[!0-9]*) die ".promote.released_stage_id must be numeric (got '$STAGE')";; esac
TOKEN="${KANBAN_WRITEBACK_TOKEN:-}"
[ -n "$TOKEN" ] || die "KANBAN_WRITEBACK_TOKEN is not set"
API="${API%/}"

# Fail-closed host guard on the config-supplied api_base BEFORE any token is sent. The
# expected host is $KANBAN_EXPECTED_HOST — REQUIRED, no baked default: this script is
# vendored by operators onto their own kanban hosts, so there is no host to safely assume.
# Pin it in the promote CI env (a repo/org variable — out-of-band from the PR-editable
# .release-pr.json, so an attacker's api_base edit can't also change the constraint). If it
# is unset/empty we refuse BEFORE any token is sent.
EXPECT_HOST="${KANBAN_EXPECTED_HOST:-}"
[ -n "$EXPECT_HOST" ] \
  || die "KANBAN_EXPECTED_HOST must be set to the expected api host before sending the writeback token; refusing to send"
host_ok "$API" \
  || die "refusing to send token — api_base '$API' is not https:// on '$EXPECT_HOST' (or a subdomain). A malicious .release-pr.json api_base can exfiltrate KANBAN_WRITEBACK_TOKEN; set KANBAN_EXPECTED_HOST to your kanban host."

# --- resolve the shipped refs (DL tokens + PR numbers) -----------------------
numlist() { grep -oE '[0-9]+' | sed 's/^0*\([0-9]\)/\1/' | awk 'NF && !seen[$0]++'; }
if [ -n "$DLS_IN" ]; then
  DL_NUMS="$(printf '%s' "$DLS_IN" | grep -oiE "$REF_RE" | numlist || true)"
  PR_NUMS=""
else
  HEAD_REF="${HEAD_REF:-HEAD}"
  [ -n "$BASE" ] || BASE="$(git describe --tags --abbrev=0 "${HEAD_REF}^" 2>/dev/null || true)"
  # An empty base would make RANGE collapse to just HEAD → git log walks ALL history
  # → every DL/PR ever committed is "shipped" → mass wrong-card move. Refuse it (the
  # first-ever release, or a shallow/tagless clone). Use --base or --dls explicitly.
  [ -n "$BASE" ] || die "no base tag found before $HEAD_REF — refusing a full-history sweep; pass --base <ref> or --dls"
  RANGE="$BASE..$HEAD_REF"
  SUBJECTS="$(git log "$RANGE" --no-merges --format='%s' 2>/dev/null || true)"
  DL_NUMS="$(printf '%s\n' "$SUBJECTS" | grep -oiE "$REF_RE" | numlist || true)"
  # The squash-merge PR marker is the TRAILING (#NNN) — not the inline #card refs.
  PR_NUMS="$(printf '%s\n' "$SUBJECTS" | grep -oE '\(#[0-9]+\)[[:space:]]*$' | numlist || true)"
fi
[ -n "$DL_NUMS$PR_NUMS" ] || { echo "promote-released-cards: no shipped refs in range — nothing to do."; exit 0; }
jarr() { printf '%s' "$1" | jq -R . | jq -s 'map(select(. != ""))'; }
DLS_J="$(jarr "$DL_NUMS")"; PRS_J="$(jarr "$PR_NUMS")"

# --- read the WHOLE board (paged) --------------------------------------------
# Auth is fed OUT-OF-BAND via process substitution (-H @<(...)) so the bearer token
# never appears in curl's argv (world-readable via `ps aux` / /proc/<pid>/cmdline on a
# multi-user host). printf is a shell builtin, so the substitution spawns no process
# whose argv carries the token. (#3569)
# --retry rides through a transient prod outage: the merge-to-main promote job
# races the operator's `bin/deploy.sh`, which drops prod into maintenance mode
# (HTTP 503) for the seconds-long deploy window (#3700). curl's --retry backs off
# exponentially on a transient error only — HTTP 408/429/5xx, a timeout, or (with
# --retry-connrefused) a refused connection — never a 4xx, so a genuine 401/404
# still fails fast. Bounded by --retry-max-time so a truly-down prod still exits.
# Card moves are idempotent (set stage N) and a 503 applies nothing, so retrying
# a PATCH is safe.
api() { curl -fsS --retry 5 --retry-connrefused --retry-max-time 60 -H @<(printf 'Authorization: Bearer %s' "$TOKEN") -H "Accept: application/json" "$@"; }
CARDS='[]'; page=1
while :; do
  RESP="$(api "$API/tasks/search.json?q=board_id=$BOARD&limit=200&page=$page")" \
    || die "board $BOARD read failed (HTTP error) — check the token and api_base ($API)"
  DATA="$(printf '%s' "$RESP" | jq -c '.data // []')"
  n="$(printf '%s' "$DATA" | jq 'length')"
  if [ "$page" -eq 1 ] && [ "${n:-0}" -eq 0 ]; then
    die "board $BOARD returned 0 visible cards — the token's user is likely not a member of board $BOARD (or wrong instance). Refusing."
  fi
  # Concatenate via STDIN, not `--argjson` — a board page can exceed MAX_ARG_STRLEN
  # (~128KB), and passing $DATA/$CARDS as a CLI arg dies "Argument list too long"
  # (the #3091 argv-overflow class; board 5 at ~98 cards crosses the cap).
  CARDS="$(printf '%s\n%s\n' "$CARDS" "$DATA" | jq -c -s 'add')"
  [ "${n:-0}" -lt 200 ] && break
  page=$((page + 1))
  [ "$page" -gt "${PROMOTE_PAGE_CAP:-50}" ] && die "promote-released-cards: result set exceeded PROMOTE_PAGE_CAP=${PROMOTE_PAGE_CAP:-50} (page=$page) — refusing to promote on a truncated board read; raise the cap or narrow"
done
# Dedup by id — defends against an API that ignores `page=` (same page each loop) or
# returns overlapping pages; otherwise a card would be PATCHed once per duplicate.
CARDS="$(printf '%s' "$CARDS" | jq -c 'unique_by(.id)')"

# --- correlate: a card ships if its dl_number OR pr_number is in the shipped sets
PLAN="$(printf '%s' "$CARDS" | jq -c --argjson dls "$DLS_J" --argjson prs "$PRS_J" '
  [ .[]
    | . as $c
    | (($c.payload.dl_number // "")|tostring|gsub("[^0-9]";"")|sub("^0+(?=.)";"")) as $cdl
    | (($c.payload.pr_number // "")|tostring|gsub("[^0-9]";"")|sub("^0+(?=.)";"")) as $cpr
    | (($cdl != "") and ($dls|index($cdl) != null)) as $byDl
    | (($cpr != "") and ($prs|index($cpr) != null)) as $byPr
    | select($byDl or $byPr)
    | { id: $c.id, stage: ($c.workflow_stage_id|tostring),
        ref: (if $byDl then "DL-\($cdl)" else "#\($cpr)" end),
        dl: (if $byDl then $cdl else null end),
        pr: (if $byPr then $cpr else null end) } ]')"

# A shipped DL with no matching card is the high-value miss (a decision whose card
# is unstamped/absent) — warn on it. Unmatched PRs are NOT reported: a PR is only a
# correlation fallback and routinely has no card (dep bumps, release commits), so
# warning on them is cry-wolf noise.
MATCHED_DLS="$(printf '%s' "$PLAN" | jq -c '[.[].dl|select(.!=null)]|unique')"
MISSING="$(jq -c -n --argjson sd "$DLS_J" --argjson md "$MATCHED_DLS" '
  [ $sd[] | select(. as $x | ($md|index($x))|not) | "DL-\(.)" ]')"

# --- move --------------------------------------------------------------------
moved=0; skipped=0; failed=0
while IFS= read -r row; do
  [ -n "$row" ] || continue
  id="$(printf '%s' "$row" | jq -r '.id')"
  cur="$(printf '%s' "$row" | jq -r '.stage')"
  ref="$(printf '%s' "$row" | jq -r '.ref')"
  if [ "$cur" = "$STAGE" ]; then echo "  = $ref (#$id): already released"; skipped=$((skipped + 1)); continue; fi
  if [ "$DRY" = 1 ]; then echo "  → $ref (#$id): would move $cur → $STAGE"; moved=$((moved + 1)); continue; fi
  if api -X PATCH -H "Content-Type: application/json" -d "{\"task\":{\"workflow_stage_id\":$STAGE}}" "$API/tasks/$id.json" >/dev/null; then
    echo "  ✓ $ref (#$id): moved $cur → $STAGE"; moved=$((moved + 1))
  else
    echo "  ✗ $ref (#$id): move failed (left in place)" >&2; failed=$((failed + 1))
  fi
done <<< "$(printf '%s' "$PLAN" | jq -c '.[]')"

nmiss="$(printf '%s' "$MISSING" | jq 'length')"
if [ "${nmiss:-0}" -gt 0 ]; then
  echo "promote-released-cards: WARNING — $nmiss shipped ref(s) matched NO card (unstamped card, or none): $(printf '%s' "$MISSING" | jq -r 'join(", ")')" >&2
fi
echo "promote-released-cards: $moved moved, $skipped already-released, $nmiss no-card, $failed failed$([ "$DRY" = 1 ] && printf ' (dry-run)')."
# --- exit policy: a "0 promoted" run is told apart by its ROOT CAUSE ----------
# Systemic move failure (a card matched but every PATCH errored) → exit 1.
if [ "$failed" -gt 0 ] && [ "$moved" = 0 ] && [ "$skipped" = 0 ]; then exit 1; fi
# Newly promoted NOTHING (moved==0) despite a non-empty shipped-ref set (an empty set
# already exited "nothing to do"). Two distinct causes, told apart by whether ref-
# derivation was COMPLETE:
#   - complete (explicit --dls, or a MERGE-commit release tip whose range carries every
#     feature/prep subject) → the derived DLs are genuinely cardless (docs-only, or tracked
#     elsewhere) → the WARNING above suffices, exit 0. An idempotent re-run of a legit
#     merge-commit release (everything already at target, skipped>0) lands here too.
#   - INCOMPLETE (a non-merge tip → the release PR was squash/rebase-merged, collapsing the
#     per-PR subjects this reads) → cards exist but went unmatched (the v0.32.0 silent-green
#     incident) → FAIL loud so the operator verifies + promotes by hand.
# NOTE: `skipped` is deliberately NOT in the guard — a squash release whose siblings were
# already promoted (a partial/earlier run) still has moved==0 and must FAIL; the legit
# merge-commit re-run is exempted by the tip check, not by skipped.
if [ "$moved" = 0 ] && [ -z "$DLS_IN" ] && ! merge_commit_tip "$HEAD_REF"; then
  die "FAILED — 0 cards newly promoted and the release tip (${HEAD_REF}) is not a merge commit. A squash/rebase merge of the release PR may have dropped the per-PR refs this derives from (use a MERGE commit for release/sync PRs — VERSIONING.md). Verify and promote manually."
fi
exit 0
