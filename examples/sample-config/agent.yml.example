# agent-webhook-bridge — per-agent configuration template.
#
# SETUP:
#   1. Copy this file to $BRIDGE_DIR/<your-agent-name>.yml
#   2. Fill in the values for your install.
#   3. `chmod 600 $BRIDGE_DIR/<your-agent-name>.yml`
#
# The FILENAME (without `.yml`) IS the agent's name and its echo "self" — there
# is no `identity.self`. The agent registry is built by scanning these files;
# there is no separate agents.json roster.
#
# PER-INSTALL settings are NOT here — they're the same for every agent on an
# install, so they live in the Laravel .env / config/bridge.php:
#   - the database (DB_CONNECTION/DB_*)
#   - the receiver public URL (BRIDGE_RECEIVER_BASE_URL)
#   - each provider's API base URL (BRIDGE_KANBAN_API_BASE_URL, ...)
#   - the secret + config base dir (BRIDGE_DIR)
# The API token is read by convention from <secret_dir>/<provider>/token.

# ----------------------------------------------------------------------------
# identity: this agent's own IMMUTABLE upstream account ids.
# ----------------------------------------------------------------------------
# Used to build the registry (resolve other agents' events to names) and to
# AUTO-SEED this agent's own echo-suppression — you never hand-list your own id.
# Omit an id the agent doesn't have. github_login is a display-only label.
identity:
  kanban_user_id: 137
  # github_user_id: 41000123
  # github_login: your-bot        # display label only; recognition keys on the id

# ----------------------------------------------------------------------------
# subscriptions: which provider scopes this agent subscribes to.
# ----------------------------------------------------------------------------
# `php artisan bridge:provision` iterates this list and ensures each kanban
# subscription exists on the upstream (idempotent). GitHub webhooks are
# configured in repo settings — bridge:provision skips github (non-zero exit).
subscriptions:
  - provider: kanban
    scopes: [5]             # kanban board IDs
    event_filter: []        # empty = all events; e.g. ["task.*", "comment.*"] to narrow

  # - provider: github
  #   scopes: ["your-org/your-repo"]   # full_name slug
  #   event_filter: ["push", "pull_request", "issues"]

# ----------------------------------------------------------------------------
# echo_suppression (optional): the agent's OWN writes are auto-suppressed from
# its identity ids above — these lists are only for OTHER agents.
# ----------------------------------------------------------------------------
# echo_suppression:
#   treat_as_echo: [other-agent]        # other agents' writes to silently skip (by name)
#   treat_as_echo_ids: ["999"]          # extra raw ids to skip (rarely needed)
#   treat_as_signal: [pm]               # if set, ONLY these agents' writes are signal
#                                       # (a name with no matching <name>.yml is rejected)

# ----------------------------------------------------------------------------
# classifier (optional): defaults to InboxOnlyClassifier (surface-only).
# ----------------------------------------------------------------------------
# classifier:
#   class: App\Bridge\Classifiers\EventDrivenClassifier

# ----------------------------------------------------------------------------
# api (optional): per-agent token-path OVERRIDE.
# ----------------------------------------------------------------------------
# The token is read by convention from <secret_dir>/<provider>/token. Override
# only when this agent authenticates as a distinct account:
# api:
#   kanban:
#     token_path: ~/.config/.../custom-kanban-token

# ----------------------------------------------------------------------------
# channel (optional): where channel_push / route_intents delivers.
# ----------------------------------------------------------------------------
# Set `socket` (local UDS) OR `url` (loopback http, e.g. an SSH tunnel) — they
# are mutually exclusive. `route_intents: true` makes the dispatcher push every
# staged intent here (config-driven EventDriven; pair with a plain classifier,
# not EventDriven, or it double-pushes).
#
# auth.token_path (HTTP transport only): a chmod-600 file holding the Bearer
# token the channel server validates (BRIDGE_CHANNEL_TOKEN). Required on a
# cross-user / multi-tenant host where loopback-bind is not the trust boundary;
# read fail-closed at push time (must be 0600, non-empty). UDS needs no token.
# On systemd Linux, prefer the uid-agnostic ${XDG_RUNTIME_DIR} form below over a
# literal /run/user/<uid>/… path: the uid drops out of config, so restoring the
# install on a host where the OS uid changed just works (a literal uid path would
# silently no-op live-wake; bridge:check warns if the parent dir is missing).
# ${XDG_RUNTIME_DIR} resolves to $XDG_RUNTIME_DIR or /run/user/<uid> when unset;
# ${uid} → the running uid. On macOS / containers without a /run/user, set an
# explicit path here AND the same BRIDGE_CHANNEL_SOCKET in the channel server env.
# channel:
#   socket: ${XDG_RUNTIME_DIR}/agent-webhook-bridge-channel-your-agent.sock
#   # url: http://127.0.0.1:8788/
#   # auth:
#   #   token_path: ~/.config/agent-webhook-bridge/secrets/channel/your-agent-token
#   route_intents: false

# ----------------------------------------------------------------------------
# surface (optional): inbox/surfacing behaviour.
# ----------------------------------------------------------------------------
# surface:
#   silent_drop_warnings: true   # warn when a channel_push target has no paired Intent
