APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ---------------------------------------------------------------------------
# Bridge
# ---------------------------------------------------------------------------
# One base dir for per-agent YAMLs + shared-identities.json + per-(provider,scope)
# HMAC secrets + per-(provider) API tokens (absolute, outside the repo).
BRIDGE_DIR=/home/agent/.config/agent-webhook-bridge
# Override either only if it lives elsewhere (both default to BRIDGE_DIR):
# BRIDGE_CONFIG_DIR=...
# BRIDGE_SECRET_DIR=...
# BRIDGE_INSTALL_SUFFIX=-prod        # -prod/-dev cross-DSN safety marker

# Per-install endpoints (same for every agent on this install).
BRIDGE_RECEIVER_BASE_URL=https://bridge.example.com/webhooks   # this bridge's public webhook URL
BRIDGE_KANBAN_API_BASE_URL=https://kanban.example.com/api/v3   # upstream API base (bridge:provision). MUST be https (DL-175) — it carries the bearer token + provision-time HMAC secret; cleartext http is rejected except loopback hosts
# BRIDGE_GITHUB_API_BASE_URL=https://api.github.com            # defaults to api.github.com

# Runtime-state dir (inbox*.jsonl, seen cursors, handler logs). Defaults to
# BRIDGE_CONFIG_DIR/state. Point it at a group-readable path OUTSIDE the 0700
# config dir when a co-located different-OS-user agent must read its own
# per-agent inbox (see docs/multi-agent.md § cross-user).
# BRIDGE_STATE_DIR=/srv/agent-bridge/state

# Inbox surfacing layout for a single install serving multiple agents:
#   shared (default) | per-agent | both
# BRIDGE_INBOX_LAYOUT=shared
# Bare `bridge:inbox` (no --agent) surfaces this agent when set:
# BRIDGE_DEFAULT_AGENT=pm
# Mode (+ optional group) applied to per-agent inbox/seen files for cross-user read:
# BRIDGE_INBOX_FILE_MODE=0640
# BRIDGE_INBOX_GROUP=agent-bridge

# spawn_detached handler — OFF by default (highest-blast-radius: RCE as the
# install user). Enable ONLY if a classifier needs to fire detached processes,
# and list each allowed program by ABSOLUTE path (comma-separated). The program
# (cmd[0]) must be in the allowlist; an empty allowlist runs nothing. Execution
# is shell-free (proc_open argv + `setsid -f`). See docs/customization.md + DL-011.
#
# ⚠ Allowlist FIXED-PURPOSE WRAPPER SCRIPTS, never an interpreter or a flag-
# flexible tool (php, bash, sh, perl, env, git, find, awk, ssh, …): the allowlist
# only constrains cmd[0], and the classifier still controls cmd[1..], so a single
# allowlisted `php`/`git` lets attacker-supplied arguments run arbitrary code
# (`php -r …`, `git -c core.sshCommand=…`) — reopening the exact RCE this guards.
# BRIDGE_SPAWN_ENABLED=true
# BRIDGE_SPAWN_ALLOWLIST=/usr/local/bin/sync-board.sh

# channel_push: a CLASSIFIER-supplied socket path (a custom classifier emitting
# its own channel_push with `socket:`) must sit under this absolute dir; unset
# ⇒ classifier-supplied sockets are refused (fail-closed). An agent's own
# `channel.socket` in its YAML is operator-authored and exempt. See DL-014.
# BRIDGE_CHANNEL_ALLOWED_SOCKET_DIR=/run/user/1006

# Global echo identities (DL-009): comma-separated provider actor ids whose
# events are NEVER a signal for ANY agent — the bridge's own machine-write
# identities (e.g. the kanban user a card-move writeback acts as), whose
# resulting card_updated webhook would otherwise loop back. Unioned into every
# agent's echo set.
# BRIDGE_GLOBAL_ECHO_IDS=4242
